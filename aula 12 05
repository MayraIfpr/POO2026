class Conta:
    def __init__(self, numero, titular, saldo=0):
        self.numero = numero
        self.titular = titular
        self.saldo = saldo

    def depositar(self, valor):
        self.saldo += valor
        print(f"Depósito de R${valor:.2f} realizado!")

    def sacar(self, valor):
        pass

    def consultarSaldo(self):
        return self.saldo

    def toString(self):
        return f"Conta: {self.numero} | Titular: {self.titular} | Saldo: R${self.saldo:.2f}"


# ==================================
# CONTA CORRENTE
# ==================================

class ContaCorrente(Conta):
    def __init__(self, numero, titular, saldo=0, limite=500):
        super().__init__(numero, titular, saldo)
        self.limite = limite

    def sacar(self, valor):

        if (self.saldo - valor) >= -self.limite:
            self.saldo -= valor
            print(f"Saque de R${valor:.2f} realizado!")
            return True

        print("Saldo insuficiente!")
        return False

    def cobrarTarifaMensal(self, taxa=10.0):
        self.saldo -= taxa
        print(f"Tarifa mensal de R${taxa:.2f} cobrada!")


# ==================================
# CONTA POUPANÇA
# ==================================

class ContaPoupanca(Conta):
    def __init__(self, numero, titular, saldo=0, taxaDeJuros=0.005):
        super().__init__(numero, titular, saldo)
        self.taxaDeJuros = taxaDeJuros

    def sacar(self, valor):

        if (self.saldo - valor) >= 0:
            self.saldo -= valor
            print(f"Saque de R${valor:.2f} realizado!")
            return True

        print("Saldo insuficiente!")
        return False

    def aplicarJuros(self):
        juros = self.saldo * self.taxaDeJuros
        self.saldo += juros
        print(f"Juros de R${juros:.2f} aplicados!")


