class Veiculo:
    def __init__(self, marca, modelo, ano):
        self.marca = marca
        self.modelo = modelo
        self.ano = ano
        self.velocidade_atual = 0

    def acelerar(self):
        self.velocidade_atual += 10
        print(f"Acelerando... Velocidade: {self.velocidade_atual} km/h")

    def frear(self):
        self.velocidade_atual -= 10

        if self.velocidade_atual < 0:
            self.velocidade_atual = 0

        print(f"Freando... Velocidade: {self.velocidade_atual} km/h")

    def info(self):
        return f"{self.marca} {self.modelo} ({self.ano}) - {self.velocidade_atual} km/h"



class Carro(Veiculo):
    def __init__(self, marca, modelo, ano, numero_portas):
        super().__init__(marca, modelo, ano)
        self.numero_portas = numero_portas

    def acelerar(self):
        self.velocidade_atual += 15
        print(f"Carro acelerando... Velocidade: {self.velocidade_atual} km/h")

    def info(self):
        return f"{self.marca} {self.modelo} ({self.ano}) - {self.numero_portas} portas - {self.velocidade_atual} km/h"




