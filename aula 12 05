class Caminhao(Veiculo):
    def __init__(self, marca, modelo, ano, capacidade_carga):
        super().__init__(marca, modelo, ano)
        self.capacidade_carga = capacidade_carga
        self.carga_atual = 0

    def acelerar(self):
        self.velocidade_atual += 5
        print(f"Caminhão acelerando... Velocidade: {self.velocidade_atual} km/h")

    def carregar(self, peso):
        self.carga_atual += peso
        print(f"Carregado {peso}kg. Carga atual: {self.carga_atual}kg")

    def descarregar(self):
        self.carga_atual = 0
        print("Carga descarregada!")

    def info(self):
        return f"{self.marca} {self.modelo} ({self.ano}) - {self.velocidade_atual} km/h - Carga: {self.carga_atual}/{self.capacidade_carga}kg"




def simular_viagem(veiculo, aceleracoes, freadas):

    print("\n--- SIMULANDO VIAGEM ---")
    print(f"Executando {aceleracoes} acelerações e {freadas} freadas\n")

    for i in range(aceleracoes):
        print(f"Aceleração {i+1}:")
        veiculo.acelerar()

    for i in range(freadas):
        print(f"\nFreada {i+1}:")
        veiculo.frear()

    print("\n--- FIM DA SIMULAÇÃO ---")




